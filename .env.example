# Rainbow Chess deployment environment.
# Copy to `.env` (next to docker-compose.yml) and fill in for your host.

# Public hostname Traefik routes to this app (must have a DNS A record).
HOSTNAME=rainbow-chess.example.com

# Name of the EXTERNAL Traefik docker network this container joins.
# Create it once with: docker network create <name>
NETWORK_NAME=traefik

# Image tag deployed by docker-compose. Normally a git commit SHA written by CI;
# defaults to "latest" if unset. The owner/repo are baked into the image name in
# docker-compose.yml (ghcr.io/<owner>/rainbow-chess) — change them there to match
# your GHCR package, e.g. ghcr.io/korjavin/rainbow-chess.
GIT_SHA=latest
